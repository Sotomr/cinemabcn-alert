# Copia a .env y rellena (no subas .env al repositorio)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Zona horaria para "hoy / mañana / pasado mañana" (por defecto Madrid)
# TIMEZONE=Europe/Madrid

# Añadir al mensaje un bloque "novedades" respecto al snapshot anterior (1 sí, 0 no)
# APPEND_NOVELTIES=1

# Máx. títulos por cine en "Otras carteleras" (Maldà, Texas…); el resto se resume con "y N más"
# DIGEST_MAX_UNSCHEDULED=15

# Máx. películas por día en Verdi con horario (0 = sin límite). Ej. 22 si el mensaje es muy largo
# DIGEST_MAX_VERDI_PER_DAY=0

# Pie con instrucciones de debug al final del mensaje (1 sí, 0 no)
# DEBUG_FOOTER=0

# Opcional: no enviar a Telegram (solo log + snapshot)
# SKIP_TELEGRAM=1
# DRY_RUN=1

# Opcional: URL base del Phenomena (por defecto se usa phenomena-experience.com/cartelera)
# PHENOMENA_BASE_URL=https://phenomena-experience.com
# ZUMZEIG_CARTELERA_URL=https://www.zumzeigcine.coop/

# TMDb: nota media + enlace IMDb en cada título (clave gratis en https://www.themoviedb.org/settings/api)
# TMDB_API_KEY=
# Máx. películas a enriquecer por ejecución (prioridad: sesiones hoy/mañana)
# TMDB_MAX_FILMS=200
# Mínimo de votos en TMDb para mostrar nota (evita ★ 1 voto y 0.0)
# TMDB_MIN_VOTES=5

# Digest: top por nota TMDb por cine y día (hoy/mañana)
# DIGEST_TOP_PER_CINEMA=5
# DIGEST_NOVELTIES_TOP_PER_CINEMA=5
# DIGEST_NOVELTIES_MAX_LINES=15
